# Launch CV — Environment Variables
# Copy this file to .env and fill in the values

# ── Database ──
DATABASE_URL="file:./dev.db"
# For production PostgreSQL:
# DATABASE_URL="postgresql://user:password@host:5432/launchcv?schema=public"

# ── Authentication ──
# Minimum 16 characters. If empty, a dev fallback is used.
AUTH_SECRET="replace-with-at-least-32-random-characters-ok"

# ── App URL ──
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Production: use https:// — session cookie will be Secure automatically
# COOKIE_SECURE="false"  # Force disable secure cookie (for HTTP dev)

# ── OpenAI (required for AI features) ──
# Never commit real keys. Copy this file to .env and paste your key there only.
OPENAI_API_KEY=""

# ── Admin Access ──
# Comma-separated emails that get admin access at /admin
ADMIN_EMAILS="admin@launch-cv.com"

# ── Email (Resend) ──
# https://resend.com — for email verification and password reset
# Put the real key only in .env (local). Never put production keys in .env.example.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"
# Set to "true" to block login for unverified emails
REQUIRE_EMAIL_VERIFICATION="false"

# ── Lemon Squeezy (Payments) ──
# https://docs.lemonsqueezy.com — API key from Settings → API
LEMON_SQUEEZY_API_KEY=""
# Store ID from Settings → Stores
LEMON_SQUEEZY_STORE_ID=""
# Variant IDs (numeric) — one per Lemon product variant. LEMON_SQUEEZY_VARIANT_ID is optional legacy fallback for Professional.
LEMON_SQUEEZY_VARIANT_ID=""
LEMON_VARIANT_STARTER=""
LEMON_VARIANT_PROFESSIONAL=""
LEMON_VARIANT_ELITE=""
LEMON_VARIANT_LIFETIME=""
# Webhook signing secret (Settings → Webhooks) — same secret length 6–40 chars as in Lemon UI
LEMON_WEBHOOK_SECRET=""
# Optional: use Lemon test mode for checkout (true / 1)
# LEMON_SQUEEZY_TEST_MODE="1"

# ── Analytics (PostHog, optional) ──
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# ── Support ──
NEXT_PUBLIC_SUPPORT_EMAIL="support@launch-cv.com"

# ── Future (optional) ──
# REDIS_URL="redis://127.0.0.1:6379"
